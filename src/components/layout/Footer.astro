---
// Footer.astro
const currentYear = new Date().getFullYear(); // Fallback SSG
---

<footer class="bg-[#0A0A0F] border-t border-[var(--color-border)] pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16">
      <!-- Brand & Tagline -->
      <div class="md:col-span-5">
        <a
          href="#"
          class="flex items-center gap-3 group inline-flex mb-6 cursor-hover"
        >
          <img
            src="/images/logo.png"
            alt="MoLoTech Logo"
            width="100"
            height="100"
            class="transform group-hover:scale-105 transition-transform"
          />
          <span
            class="font-display font-bold text-xl tracking-tight text-white group-hover:text-[var(--color-accent-light)] transition-colors"
          >
            MoLoTech
          </span>
        </a>
        <p
          class="text-[var(--color-text-secondary)] font-body leading-relaxed max-w-sm mb-6"
        >
          Soluciones digitales asombrosas a medida para resolver las necesidades
          más exigentes de tu negocio desde Bogotá para el mundo.
        </p>
        <div class="flex gap-4">
          <!-- LinkedIn -->
          <a
            href="https://linkedin.com/company/molotech"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-accent-light)] hover:border-[var(--color-accent-light)] hover:bg-[var(--color-accent-glow)] transition-all cursor-hover"
            aria-label="LinkedIn"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path><rect width="4" height="12" x="2" y="9"></rect><circle
                cx="4"
                cy="4"
                r="2"></circle></svg
            >
          </a>
          <!-- GitHub -->
          <a
            href="https://github.com/molotech"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-secondary)] hover:text-white hover:border-white transition-all cursor-hover"
            aria-label="GitHub"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3-.3 6-1.5 6-6.5a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 5 3 6.2 6 6.5a4.8 4.8 0 0 0-1 3.2v4"
              ></path><path d="M9 18c-4.5 1-5-2.5-7-3"></path></svg
            >
          </a>
          <!-- Instagram -->
          <a
            href="https://instagram.com/molotech"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[#E1306C] hover:border-[#E1306C] transition-all cursor-hover"
            aria-label="Instagram"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg
            >
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="md:col-span-3">
        <h4 class="font-display font-semibold text-white mb-6">Navegación</h4>
        <ul class="space-y-4">
          <li>
            <a
              href="#hero"
              class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent-light)] transition-colors inline-block cursor-hover"
              >Inicio</a
            >
          </li>
          <li>
            <a
              href="#about"
              class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent-light)] transition-colors inline-block cursor-hover"
              >Nosotros</a
            >
          </li>
          <li>
            <a
              href="#services"
              class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent-light)] transition-colors inline-block cursor-hover"
              >Soluciones</a
            >
          </li>
          <li>
            <a
              href="#portfolio"
              class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent-light)] transition-colors inline-block cursor-hover"
              >Portafolio</a
            >
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-4">
        <h4 class="font-display font-semibold text-white mb-6">Sede Central</h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3 text-[var(--color-text-secondary)]">
            <svg
              class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            >
            <span
              >Bogotá, Colombia. <br /> Atendemos a clientes de toda la región LA.</span
            >
          </li>
          <li class="flex items-start gap-3 text-[var(--color-text-secondary)]">
            <svg
              class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
            >
            <a
              href="mailto:molotechsolutions@gmail.com"
              class="hover:text-[var(--color-accent-light)] transition-colors cursor-hover"
              >molotechsolutions@gmail.com</a
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div
      class="border-t border-[var(--color-border)] pt-8 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="text-[var(--color-text-muted)] text-sm">
        &copy; <span id="current-year">{currentYear}</span> MoLoTech. Todos los derechos
        reservados.
      </p>
      <div class="flex gap-6">
        <a
          href="#"
          class="text-[var(--color-text-muted)] hover:text-white text-sm transition-colors cursor-hover"
          >Políticas de Privacidad</a
        >
        <a
          href="#"
          class="text-[var(--color-text-muted)] hover:text-white text-sm transition-colors cursor-hover"
          >Términos de Servicio</a
        >
      </div>
    </div>
  </div>

  <!-- Schema Complementario de Organización de nivel Footer con Address -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "MoLoTech",
      "url": "http://localhost:4321",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bogotá",
        "addressCountry": "CO"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "email": "molotechsolutions@gmail.com",
        "availableLanguage": ["Spanish", "English"]
      }
    }
  </script>
</footer>

<script>
  // Año dinámico por JS vanilla asegurando inmutabilidad ante caché SSG
  const yearEl = document.getElementById("current-year");
  if (yearEl) yearEl.textContent = new Date().getFullYear().toString();
</script>
