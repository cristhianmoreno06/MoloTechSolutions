---
// ContactCTA.astro
---

<section
  id="contact"
  class="py-[var(--space-section-mobile)] md:py-[var(--space-section)] bg-[var(--color-bg-secondary)] relative overflow-hidden"
>
  <!-- Efectos de fondo sutiles -->
  <div
    class="absolute top-0 right-[-10%] w-[500px] h-[500px] rounded-full bg-[var(--color-accent)] opacity-[0.03] blur-[100px] pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 left-[-10%] w-[500px] h-[500px] rounded-full bg-[#06B6D4] opacity-[0.03] blur-[100px] pointer-events-none"
  >
  </div>

  <div
    class="max-w-7xl mx-auto px-6 relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center"
  >
    <!-- Texto e info de contacto -->
    <div data-reveal>
      <h2
        class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-white mb-6 leading-tight"
      >
        ¿Listo para acelerar tu <br /><span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-accent)] to-[#06B6D4]"
          >Transformación Digital</span
        >?
      </h2>
      <p
        class="text-[var(--color-text-secondary)] font-body text-lg mb-8 max-w-lg leading-relaxed"
      >
        Agenda una consulta de viabilidad técnica sin costo. Nuestro equipo de
        ingenieros analizará tu idea para estructurar la ruta de ejecución
        óptima.
      </p>

      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div
            class="w-12 h-12 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-primary)] flex items-center justify-center text-[var(--color-accent)] shrink-0"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
          </div>
          <div>
            <span
              class="block text-sm text-[var(--color-text-muted)] font-medium mb-1"
              >WhatsApp Business</span
            >
            <a
              href="https://wa.me/573185407442"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white font-medium hover:text-[var(--color-accent-light)] transition-colors cursor-hover"
            >
              +57 (318) 540-7442
            </a>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div
            class="w-12 h-12 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-primary)] flex items-center justify-center text-[var(--color-accent)] shrink-0"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
            >
          </div>
          <div>
            <span
              class="block text-sm text-[var(--color-text-muted)] font-medium mb-1"
              >Email directo</span
            >
            <a
              href="mailto:molotechsolutions@gmail.com"
              class="text-white font-medium hover:text-[var(--color-accent-light)] transition-colors cursor-hover"
            >
              molotechsolutions@gmail.com
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Formulario -->
    <div
      data-reveal
      data-reveal-delay="200"
      class="bg-[var(--color-bg-primary)] border border-[var(--color-border)] rounded-2xl p-8 shadow-2xl relative"
    >
      <!-- Decoración de tarjeta -->
      <div
        class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[var(--color-accent)] to-[#06B6D4] rounded-t-2xl"
      >
      </div>

      <form
        action="https://formspree.io/f/mzdyokzq"
        method="POST"
        class="space-y-5"
      >
        <!-- Asunto personalizado -->
        <input type="hidden" name="_subject" value="contacto web page" />
        <div>
          <label
            for="name"
            class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2"
            >Nombre completo</label
          >
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] transition-all"
            placeholder="Ej: Elon Musk"
          />
        </div>

        <div>
          <label
            for="email"
            class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2"
            >Correo electrónico</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] transition-all"
            placeholder="ejemplo@empresa.com"
          />
        </div>

        <div>
          <label
            for="message"
            class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2"
            >Háblanos sobre tu proyecto</label
          >
          <textarea
            id="message"
            name="message"
            required
            rows="4"
            class="w-full bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] transition-all resize-none"
            placeholder="Tenemos una idea para modernizar nuestro flujo de trabajo..."
          ></textarea>
        </div>

        <!-- Honey pot field para bots -->
        <input type="text" name="_gotcha" style="display:none" />

        <button
          type="submit"
          class="w-full py-4 rounded-lg bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-semibold flex justify-center items-center gap-2 transition-colors cursor-hover shadow-[0_0_15px_var(--color-accent-glow)]"
        >
          Enviar mensaje
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
              points="22 2 15 22 11 13 2 9 22 2"></polygon></svg
          >
        </button>
      </form>
    </div>
  </div>
</section>
